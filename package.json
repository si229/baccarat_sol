{
  "name": "baccarat_sol",
  "version": "1.0.0",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "init:env": "powershell -ExecutionPolicy Bypass -File scripts/init-env.ps1",
    "init:windows": "powershell -ExecutionPolicy Bypass -File scripts/init-local.ps1 all",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/init-local.ps1 setup",
    "deploy:localhost": "hardhat run scripts/deploy.js --network localhost",
    "doctor:localhost": "hardhat run scripts/doctor.js --network localhost",
    "stress:web": "node scripts/serve-stress.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "typechain": "^8.3.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  }
}
